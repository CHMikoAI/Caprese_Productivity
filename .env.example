# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; this template is safe to commit (no real secrets).

# 4-digit PIN for the gate shown when opening the app
APP_PASSWORD=1234

# Supabase project — Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co

# Secret (service-role) key — SERVER ONLY. Bypasses row-level security.
# Never prefix with NEXT_PUBLIC_ and never expose it to the browser.
# Project Settings -> API Keys -> "service_role" (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
